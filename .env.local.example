# Copy to .env.local for local dev. Set in Vercel Project → Settings → Environment Variables for production.

# Resend API key — used by the contact form (Phase 4). Sign up at resend.com.
RESEND_API_KEY=

# Where contact form submissions are emailed.
CONTACT_TO_EMAIL=hello@novawerk.io

# Public site URL — used for absolute URLs in metadata, sitemap, OG images.
NEXT_PUBLIC_SITE_URL=https://novawerk.io
