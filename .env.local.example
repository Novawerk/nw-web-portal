# Copy to .env.local for local dev. Set in Vercel Project → Settings → Environment Variables for production.

# --- Payload CMS ---

# Postgres connection string. Recommend Neon (https://neon.tech) free tier.
# In Vercel: Project → Storage → Create Database → Postgres (Neon-backed); env auto-injected.
DATABASE_URI=postgres://user:password@host:5432/nw_web_portal

# Random 32+ char string used to sign session cookies. Generate with: openssl rand -base64 48
PAYLOAD_SECRET=

# Vercel Blob token for media uploads. Vercel project → Storage → Create → Blob → copy token.
BLOB_READ_WRITE_TOKEN=

# Public-facing app URL (used by Payload for callbacks, OG images, etc.)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Contact form (Resend) ---

# Resend API key — used by the contact form. Sign up at resend.com.
RESEND_API_KEY=

# Where contact form submissions are emailed.
CONTACT_TO_EMAIL=hello@novawerk.io

# Verified Resend "from" address. Defaults to NovaWerk <hello@novawerk.io>.
CONTACT_FROM_EMAIL=

# --- Site ---

# Public site URL — used for absolute URLs in metadata, sitemap, OG images.
NEXT_PUBLIC_SITE_URL=https://novawerk.io
