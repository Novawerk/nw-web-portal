# Copy to .env.local for local dev. Set in Vercel → Settings → Environment Variables for production.
# Never commit .env*.local — only this *.example file is tracked.

# --- Database ---

# Direct Postgres connection string (sslmode=require). Recommend Neon (https://neon.tech).
# Either DATABASE_URI (Payload convention) or DATABASE_URL (Vercel/Neon) works — payload.config.ts falls back.
# In Vercel, the Vercel-Neon marketplace integration injects DATABASE_URL as an OIDC sensitive var
# that *cannot* be pulled to local dev — so for local dev use a direct Neon string here.
DATABASE_URI=postgres://user:password@host:5432/nw_web_portal

# --- Payload CMS ---

# Random 32+ char string used to sign session cookies. Generate with: openssl rand -base64 48
PAYLOAD_SECRET=

# Vercel Blob token for media uploads. Vercel project → Storage → Create → Blob → copy token.
BLOB_READ_WRITE_TOKEN=

# --- Site ---

# Public-facing app URL. Used by Payload for callbacks, OG images, etc.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Public site URL — used for absolute URLs in metadata, sitemap, OG images.
NEXT_PUBLIC_SITE_URL=https://novawerk.io

# --- Contact form (Resend) ---

# Resend API key — used by the contact form and newsletter signup.
# If unset, lib/email.ts falls back to console.log and the Payload write is the record.
RESEND_API_KEY=

# Where contact form submissions are emailed.
CONTACT_TO_EMAIL=hello@novawerk.io

# Verified Resend "from" address. Defaults to: Novawerk <hello@novawerk.io>
CONTACT_FROM_EMAIL=
